# ===========================================
# Sawaari Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# ===========================================
# SERVER CONFIG
# ===========================================
PORT=8080
ENVIRONMENT=development
LOG_LEVEL=info

# ===========================================
# DATABASE (PostgreSQL + PostGIS)
# ===========================================
DATABASE_URL=postgres://sawaari:sawaari_secret@localhost:5432/sawaari?sslmode=disable
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sawaari
POSTGRES_PASSWORD=sawaari_secret
POSTGRES_DB=sawaari

# ===========================================
# CACHE (Valkey/Redis)
# ===========================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ===========================================
# KAFKA (Event Bus)
# ===========================================
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=sawaari-backend
KAFKA_TOPICS_bus_positions=bus.positions
KAFKA_TOPICS_quotes_issued=quotes.issued
KAFKA_TOPICS_quotes_feedback=quotes.feedback
KAFKA_TOPICS_bookings_state=bookings.state
KAFKA_TOPICS_alerts_fired=alerts.fired
KAFKA_TOPICS_tariffs_changed=tariffs.changed

# ===========================================
# CLICKHOUSE (Analytics)
# ===========================================
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=sawaari
CLICKHOUSE_PASSWORD=clickhouse_secret
CLICKHOUSE_DATABASE=sawaari

# ===========================================
# MINIO / S3 (Object Storage)
# ===========================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_secret
S3_BUCKET_TICKETS=sawaari-tickets
S3_BUCKET_GTFS=sawaari-gtfs
S3_BUCKET_QR=sawaari-qr
S3_REGION=us-east-1

# ===========================================
# ROUTING SERVICES
# ===========================================
OTP2_URL=http://localhost:8080
VALHALLA_URL=http://localhost:8002
PHOTON_URL=http://localhost:2322

# ===========================================
# AUTHENTICATION
# ===========================================
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_use_32_chars_minimum
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=30

# ===========================================
# EXTERNAL APIs
# ===========================================

# Open Trip Data (Delhi GTFS)
OTD_API_KEY=your_otd_api_key
OTD_STATIC_URL=https://otd.delhi.gov.in/api/gtfs/static
OTD_RT_URL=https://otd.delhi.gov.in/api/gtfs/realtime

# SMS/OTP (MSG91)
MSG91_API_KEY=your_msg91_api_key
MSG91_SENDER_ID=SAWAAR

# Firebase Cloud Messaging
FCM_CREDENTIALS_PATH=/app/firebase-key.json

# ===========================================
# PROVIDER API KEYS
# ===========================================
UBER_CLIENT_ID=your_uber_client_id
UBER_CLIENT_SECRET=your_uber_client_secret
OLA_API_KEY=your_ola_api_key
RAPIDO_API_KEY=your_rapido_api_key

# ===========================================
# ONDC (Beckn Protocol)
# ===========================================
ONDC_GATEWAY_URL=https://api.beckn.org
ONDC_SUBSCRIBER_ID=your_subscriber_id
ONDC_SUBSCRIBER_KEY=your_subscriber_key
ONDC_ENVIRONMENT=sandbox

# ===========================================
# MAPS & LOCATION
# ===========================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
OLA_MAPS_API_KEY=your_ola_maps_api_key

# ===========================================
# FARES & TARIFFS
# ===========================================
# Delhi Auto Tariff (Jan 2023)
AUTO_BASE_FARE=30
AUTO_PER_KM=10.5
AUTO_PER_MINUTE=1.55
AUTO_MIN_FARE=35

# Delhi Metro Tariff (Aug 2025)
METRO_MIN_FARE=11
METRO_MAX_FARE=64

# DTC Bus Tariff
BUS_BASE_FARE=5
BUS_AC_FARE=15

# ===========================================
# SAHELI FLAG (Aug 1, 2026)
# ===========================================
SAHELI_ENABLED=true
SAHELI_EFFECTIVE_DATE=2026-08-01

# ===========================================
# MONITORING
# ===========================================
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000
METRICS_ENABLED=true

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ===========================================
# CORS
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
