# ===========================================
# Sawaari Flutter App Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# ===========================================
# API CONFIGURATION
# ===========================================
API_BASE_URL=https://api.sawaari.in
API_TIMEOUT_SECONDS=30

# ===========================================
# AUTHENTICATION
# ===========================================
AUTH_TOKEN_KEY=auth_token
REFRESH_TOKEN_KEY=refresh_token

# ===========================================
# MAPS
# ===========================================
# Default: Self-hosted OSM tiles (free)
MAP_TILE_URL=https://tiles.sawaari.in
MAP_ATTRIBUTION=© OpenStreetMap contributors

# Alternative: Google Maps (paid)
GOOGLE_MAPS_IOS_KEY=your_ios_key
GOOGLE_MAPS_ANDROID_KEY=your_android_key

# Alternative: Ola Maps (INR pricing)
OLA_MAPS_KEY=your_ola_maps_key

# ===========================================
# FEATURES
# ===========================================
ENABLE_OFFLINE_MODE=true
ENABLE_SAHELI=true
ENABLE_LIVE_TRACKING=true

# ===========================================
# ENVIRONMENT
# ===========================================
ENVIRONMENT=development
DEBUG_MODE=true

# ===========================================
# ANALYTICS
# ===========================================
FIREBASE_ANALYTICS_ENABLED=true
CRASHLYTICS_ENABLED=true

# ===========================================
# GTFS CONFIG
# ===========================================
# Bundled GTFS for offline mode
GTFS_VERSION=2026-07-01
GTFS_VALID_UNTIL=2026-08-01
